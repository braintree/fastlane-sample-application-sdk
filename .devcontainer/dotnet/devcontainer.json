{
    "name": "Dotnet",
    "image": "mcr.microsoft.com/devcontainers/dotnet:8.0",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}/server/dotnet",
    "forwardPorts": [
        5000,
        5001
    ],
    "portsAttributes": {
        "5000": {
            "label": "Dotnet HTTP",
            "onAutoForward": "openBrowserOnce"
        },
        "5001": {
            "label": "Dotnet HTTPS",
            "onAutoForward": "openBrowserOnce"
        }
    },
    "secrets": {
        "BRAINTREE_MERCHANT_ID": {
            "description": "Sandbox merchant ID of the application.",
            "documentationUrl": "https://www.braintreepayments.com/sandbox"
        },
        "BRAINTREE_PUBLIC_KEY": {
            "description": "Sandbox public key of the application.",
            "documentationUrl": "https://www.braintreepayments.com/sandbox"
        },
        "BRAINTREE_PRIVATE_KEY": {
            "description": "Sandbox private key of the application.",
            "documentationUrl": "https://www.braintreepayments.com/sandbox"
        }
    },
    "containerEnv": {
        "BASE_URL": "https://api-m.sandbox.paypal.com"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "vsls-contrib.codetour",
                "PayPal.vscode-paypal",
                "ms-dotnettools.csharp"
            ]
        },
        "settings": {
            "git.openRepositoryInParentFolders": "always"
        },
        "codespaces": {
            "openFiles": [
                "README.md"
            ]
        }
    },
    "postCreateCommand": "cd /workspaces/${localWorkspaceFolderBasename}/server && cp .env.example dotnet/.env && cd dotnet && dotnet restore",
    "postAttachCommand": "dotnet run"
}